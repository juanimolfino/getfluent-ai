# Supabase - Auth, Postgres, Storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ai-results

# Drizzle - Supabase Postgres connection string
DATABASE_URL=

# Inngest - async job runner
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe - checkout, subscriptions, webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_CREDITS_10=
STRIPE_PRICE_ID_CREDITS_50=
STRIPE_PRICE_ID_PRO_MONTHLY=

# AI providers - existing boilerplate jobs
FAL_KEY=
OPENAI_API_KEY=

# Fluent conversation AI
ANTHROPIC_API_KEY=

# ElevenLabs - AI voice text-to-speech
ELEVENLABS_API_KEY=
# Optional: override default voice ID. Default is Rachel, warm American English.
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Deepgram - premium voice-to-text input
DEEPGRAM_API_KEY=
DEEPGRAM_TEMP_TOKEN_TTL_SECONDS=30
DEEPGRAM_FLUX_MODEL=flux-general-en
DEEPGRAM_FLUX_EOT_THRESHOLD=0.9
DEEPGRAM_FLUX_EOT_TIMEOUT_MS=10000
# Rollback: set this to browser to disable Deepgram input without changing code.
NEXT_PUBLIC_PREMIUM_STT_PROVIDER=browser
NEXT_PUBLIC_STT_DEBUG_LOGS=false
STT_DEBUG_LOGS=false
DEEPGRAM_TOKEN_GRANT_RATE_LIMIT_WINDOW_SECONDS=60
DEEPGRAM_TOKEN_GRANTS_PER_USER_PER_WINDOW=12
DEEPGRAM_TOKEN_GRANTS_PER_SESSION_PER_WINDOW=8

# Upstash Redis - per-user job concurrency limit
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend - optional transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
HEALTHCHECK_SECRET=
FREE_SIGNUP_CREDITS=5
FREE_MONTHLY_CREDITS=5
PRO_MONTHLY_CREDITS=100
MAX_CONCURRENT_JOBS=3
